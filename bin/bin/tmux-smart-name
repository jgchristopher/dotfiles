#!/usr/bin/env bash
# Smart tmux window naming with worktree detection

COMMAND="$1"
CURRENT_PATH="$2"
PANE_PID="$3"

# Claude Code runs as a native binary whose comm is `claude`, but tmux's
# pane_current_command reports the pane's *foreground* process — for an active
# session that's whatever tool it's running (bash/node/uv/...), never `claude`.
# So detect Claude by scanning the pane's process subtree for a `claude`
# process. Matches lowercase `claude` only, so the Claude.app desktop helpers
# (comm `Claude`) can't false-positive.
pane_has_claude() {
  local root="$1"
  [ -n "$root" ] || return 1
  ps -axo pid=,ppid=,comm= | awk -v root="$root" '
    { ppid[$1] = $2; comm[$1] = $3 }
    END {
      n = 0; queue[n++] = root
      for (i = 0; i < n; i++) {
        for (p in ppid) if (ppid[p] == queue[i]) queue[n++] = p
        if (comm[queue[i]] ~ /(^|\/)claude$/) exit 0
      }
      exit 1
    }
  '
}

if pane_has_claude "$PANE_PID"; then
  COMMAND="claude"
fi

# Get icon from nerdwin
ICON=$(nerdwin "$COMMAND")

# Get smart directory name
get_smart_name() {
  local path="$1"
  local dir_name=$(basename "$path")

  # Check if we're in a git worktree (where .git is a file, not a directory)
  if [ -f "$path/.git" ]; then
    local parent_dir=$(dirname "$path")
    local parent_name=$(basename "$parent_dir")
    local branch=$(cd "$path" && git rev-parse --abbrev-ref HEAD 2>/dev/null)

    # claude --work-tree pattern: <project>/.claude/worktrees/<worktree>
    local grandparent_dir=$(dirname "$parent_dir")
    if [ "$parent_name" = "worktrees" ] && [ "$(basename "$grandparent_dir")" = ".claude" ]; then
      local project=$(basename "$(dirname "$grandparent_dir")")
      if [ -n "$branch" ] && [ "$branch" != "HEAD" ]; then
        echo "$project ($branch)"
      else
        echo "$project ($dir_name)"
      fi
      return
    fi

    # Bare-repo worktree pattern: <project>/.bare + <project>/<worktree>
    if [ -d "$parent_dir/.bare" ]; then
      local project=$(basename "$parent_dir")
      if [ -n "$branch" ]; then
        echo "$project ($branch)"
        return
      fi
    fi
  fi

  # Default: just show directory name
  echo "$dir_name"
}

NAME=$(get_smart_name "$CURRENT_PATH")

# Output icon and name
echo "$ICON $NAME"
