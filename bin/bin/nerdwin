#!/usr/bin/env bash
# Based on https://github.com/joshmedeski/tmux-nerd-font-window-name
# Based on Nick Nisi version

NAME=$1
SHOW_NAME="$(tmux show -gqv '@tmux-nerd-font-window-name-show-name')"

function get_shell_icon() {
  local default_shell_icon="¯×ò"
  local shell_icon
  shell_icon="$(tmux show -gqv '@tmux-nerd-font-window-name-shell-icon')"
  if [ "$shell_icon" != "" ]; then
    echo "$shell_icon"
  else
    echo "$default_shell_icon"
  fi
}

SHELL_ICON=$(get_shell_icon)

get_icon() {
  case $NAME in
  tmux)
    echo "¯»ê"
    ;;
  htop | top)
    echo "¯«ó"
    ;;
  fish | zsh | bash | tcsh)
    echo "$SHELL_ICON"
    ;;
  vi | vim | nvim | lvim)
    echo "¯ÿ½"
    ;;
  lazygit | git | tig)
    echo "¯£é"
    ;;
  claude)
    echo "¾▒Ö║"
    ;;
  node)
    echo "¾░ÄÖ"
    ;;
  ruby)
    echo "¯ê¥"
    ;;
  go)
    echo "¯£ñ"
    ;;
  lf | lfcd)
    echo "´ü╝"
    ;;
  beam | beam.smp) # Erlang runtime
    echo "¯ëÁ"
    ;;
  rustc | rustup)
    echo "¯×¿"
    ;;
  Python)
    echo "¯£╝"
    ;;
  *)
    if [ "$SHOW_NAME" = true ]; then
      echo "´ä¿"
    else
      echo "$NAME"
    fi
    ;;
  esac
}

ICON=$(get_icon)

if [ "$SHOW_NAME" = true ]; then
  echo "$ICON" "$NAME"
else
  echo "$ICON" "$NAME"
fi
